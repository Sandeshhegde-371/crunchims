# ─────────────────────────────────────────────────────────────────────────────
# IMS SQL Agent - Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL Database ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory
DB_USER=ims_readonly          # Use a READ-ONLY PostgreSQL user
DB_PASSWORD=your_password_here

# Connection pool
DB_MIN_CONN=1
DB_MAX_CONN=10
DB_TIMEOUT=10                 # Connection timeout in seconds

# ── External AI API ───────────────────────────────────────────────────────────
AI_API_ENDPOINT=https://your-ai-api-endpoint.com/generate
AI_API_TOKEN=your_bearer_token_here
AI_USERNAME=                  # Optional - include if required by your AI API

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# ── SQL Agent Settings ────────────────────────────────────────────────────────
MAX_RESULT_ROWS=50            # Max rows fetched from DB per query
MAX_AI_EXPLAIN_ROWS=20        # Max rows sent to AI for explanation (truncates)
MAX_RETRIES=1                 # Number of retry attempts on DB error

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false                   # Set to true for verbose logs + auto-reload
